# Remote Laravel API (no trailing slash on base)
# Lokale Herd-site (zelfde domein als /login op de website)
REMOTE_API_BASE_URL=https://timetraq.test

# Activity sync endpoint path (appended to REMOTE_API_BASE_URL)
REMOTE_ACTIVITY_PATH=/api/activity

# Login endpoint path (Bearer token in JSON response: access_token or token)
REMOTE_LOGIN_PATH=/api/login

# How often the active window poller samples (ms)
ACTIVE_WINDOW_POLL_MS=5000

# How often queued activities are batched to the remote API (ms)
SYNC_INTERVAL_MS=60000

# Max activities per HTTP batch
SYNC_BATCH_SIZE=50

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Optioneel: pad naar Herd CA (alleen nodig als auto-detect faalt)
# HERD_CA_PATH=/Users/you/Library/Application Support/Herd/config/valet/CA/LaravelValetCASelfSigned.pem
