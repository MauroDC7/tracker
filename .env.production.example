# Jouw live Laravel API (geen trailing slash, geen .test)
REMOTE_API_BASE_URL=https://jouw-domein.be

REMOTE_ACTIVITY_PATH=/api/activity
REMOTE_LOGIN_PATH=/api/login

ACTIVE_WINDOW_POLL_MS=5000
SYNC_INTERVAL_MS=60000
SYNC_BATCH_SIZE=50
LOG_LEVEL=info
