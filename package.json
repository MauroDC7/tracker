{
  "name": "timetraq-tracker",
  "productName": "Timetraq Tracker",
  "version": "1.0.0",
  "description": "Privacy-first desktop activity metadata tracker for Timetraq",
  "main": "dist/main/index.js",
  "author": "Timetraq",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "start": "npm run build && electron .",
    "dev": "concurrently \"npm run watch\" \"wait-on dist/main/index.js && electron .\"",
    "pack": "npm run build && electron-builder --dir",
    "dist:win": "node scripts/prepare-release.js && npm run build && electron-builder --win",
    "dist:mac": "node scripts/prepare-release.js && xattr -cr assets static node_modules/active-win 2>/dev/null; npm run build && electron-builder --mac",
    "dist:all": "node scripts/prepare-release.js && npm run build && electron-builder --win --mac",
    "release:prepare": "node scripts/prepare-release.js",
    "icons": "node scripts/sync-icons.js",
    "prebuild": "npm run icons",
    "prestart": "npm run icons",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "active-win": "^9.0.0",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "app.timetraq.tracker",
    "productName": "Timetraq Tracker",
    "npmRebuild": false,
    "afterPack": "scripts/after-pack-mac.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "static/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/active-win/**/*"
    ],
    "asarUnpack": [
      "node_modules/active-win/**"
    ],
    "extraResources": [
      {
        "from": "static",
        "to": "static"
      },
      {
        "from": ".env.release",
        "to": ".env"
      }
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "icon": "assets/icon.png",
    "mac": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "identity": null,
      "entitlementsInherit": "build/entitlements.mac.plist",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office"
    }
  }
}
